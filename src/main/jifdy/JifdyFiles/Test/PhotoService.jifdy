public class PhotoService {

    public void low client() {

        String low user = "Alice";
        String high password = "1234";
        String high photo = "BINARYDATA";

        // SEND LOGIN
        e(Server(Login) low loginMsg =
            encrypt(kServer, Login(String low user, String high password)));

        send(loginMsg);

        // SEND UPLOAD
        e(Server(Upload) low uploadMsg =
            encrypt(kServer,
                Upload(String low user, String high photo)));

        send(uploadMsg);

        boolean low ok = true;

        // RECEIVE ACK
        try_rcv(encrypt(kClient,
            Ack(String low msg)
        )) {
            // receive FAILED → mark failure
            ok = false;
        }

        // Only use msg if receive succeeded
        if (ok) {
            print(msg);   // LOW
        }
    }


    public void low server() {

        boolean low ok = true;

        // RECEIVE LOGIN
        try_rcv(encrypt(kServer,
            Login(String low user, String high password)
        )) {
            ok = false;
        }

        // RECEIVE UPLOAD
        if (ok) {
            try_rcv(encrypt(kServer,
                Upload(String low user2, String high photo)
            )) {
                ok = false;
            }
        }

        // PROCESS
        if (ok) {

            store(photo);  // HIGH variable

            e(Client(Ack) low ackMsg =
                encrypt(kClient, Ack(String low "uploaded")));

            send(ackMsg);
        }
    }
}
