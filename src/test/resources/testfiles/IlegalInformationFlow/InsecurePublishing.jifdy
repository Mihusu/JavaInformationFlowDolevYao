key kEditor;
key kPublisher;
format Submission(String low title, String high manuscript);
format Approval(String low title, String high review);
public class InsecurePublishing {

    int low publicationCounter = 0;

    public void low author() {

        String low title = "Security";
        String high manuscript = "TOP_SECRET_BOOK";

        e(kEditor, Submission) low submissionMsg =
            e(kEditor, Submission(title, manuscript));

        send(submissionMsg);
    }


    public void low editor() {

        bool high ok = true;
        String low title = "";
        String high manuscript = "";

        try_rcv(
            e(kEditor,
                Submission(t, m))
        ) {
            ok = false;
        }

        title = t;
        manuscript = m;

        if (ok) {

            // Illegal information flow in initialization
            String low review = "REJECTED";

            print(review);

            e(kPublisher, Approval) low approvalMsg =
                e(kPublisher, Approval(title, review));

            send(approvalMsg);
        }
    }


    public void low publisher() {

        bool low ok = true;
        String low title = "";
        String high review = "";

        try_rcv(
            e(kPublisher,
                Approval(t, r))
        ) {
            ok = false;
        }

        title = t;
        review = r;

        if (ok) {

            publicationCounter = publicationCounter + 1;

            print(title, publicationCounter);
        }
    }
}
