            e(kPublic, MedicalData(patientName, diagnosis, patientId));

        send(medicalMsg);

        try_rcv(
            e(kPatient, Result(received))) {
        }
    }


    public void low hospital() {

        bool high ok = true;
        String low patientName = "";
        String high diagnosis = "";
        int high patientId = 0;

        try_rcv(
            e(kPublic,
                MedicalData(
                    pName,
                    receivedDiagnosis,
                    pid))
        ) {
