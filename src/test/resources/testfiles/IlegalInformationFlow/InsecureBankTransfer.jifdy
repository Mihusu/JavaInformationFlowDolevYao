public class InsecureBankTransfer {

    int low publicTotal = 0;
    int high secureTotal = 0;

    public void low client() {

        String low sender = "Alice";
        String low receiver = "Bob";

        int high amount1 = 5000;
        int high amount2 = 7000;

        e(kClientBank, Transfer1) low transfer1 =
