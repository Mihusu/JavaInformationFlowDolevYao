    }


    public void low bank() {

        bool high ok = true;
        int high amount1;
        int high amount2;

        while (ok) {

            // Input of the bank
            String high sender_in = "";
            String high receiver_in = "";
            int high amount_in = 0;

            try_rcv(e(kClientBank,
                Transfer1(sender, receiver, amount1)
            )) {
                ok = false;
            }

            // Second transfer
            try_rcv(e(kClientBank,
              Transfer2(user, receiver, amount2)
            )) {
                ok = false;
            }

            sender_in = sender;
            receiver_in = receiver;
            amount_in = amount1;

            if (ok) {

