public class InsecureBankTransfer {

    int low publicTotal = 0;
    int high secureTotal = 0;

    public void low client() {

        String low sender = "Alice";
        String low receiver = "Bob";

        int high amount1 = 5000;
        int high amount2 = 7000;

        e(kClient, Transfer1) low transfer1 =
            e(kBank, Transfer1(String low sender, String low receiver, int high amount1));

        e(kClient, Transfer2) low transfer2 =
            e(kBank, Transfer2(String low sender, String low receiver, int high amount2));

        send(transfer1);
        send(transfer2);
    }


    public void low bank() {

        bool high ok = true;
        int high amount1;
        int high amount2;

        while (ok) {

            // Input of the bank
            String high sender_in = "";
            String high receiver_in = "";
            int high amount_in = 0;

            try_rcv(
                e(kBank,
                    Transfer1(
                        String low sender,
                        String low receiver,
                        int high amount1))
            ) {
                ok = false;
            }

            // Second transfer
            try_rcv(e(kBank,
              Transfer2(String low user, int high amount2, String low target)
            )) {
                ok = false;
            }

            sender_in = sender;
            receiver_in = receiver;
            amount_in = amount1;

            if (ok) {

                secureTotal = secureTotal + amount_in;

                // ILLEGAL FLOW
                publicTotal = secureTotal;

                print(sender_in, receiver_in, publicTotal);

                if (publicTotal > 10000) {
                    ok = false;
                }
            }
        }

        e(kBank, Result(int low publicTotal)) low resultMsg =
            e(kClient, Result(publicTotal));

        send(resultMsg);
    }
}