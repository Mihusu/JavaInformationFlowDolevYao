key kAuthorEditorPublisher;
format Submission(String low title, String high manuscript);
format Published(String low title_in, int low publications_in);
format Approval(String low title_in, String high review);

public class PublishingSystem {

    int low publications;
    String low title = "Secure Compilation";
    String high manuscript = "SECRET_BOOK_CONTENT";

    // AUTHOR
    public void low author() {

        e(kAuthorEditorPublisher, Submission) low submissionMsg =
            e(kAuthorEditorPublisher, Submission(title, manuscript));

        send(submissionMsg);

        try_rcv(
            e(kAuthorEditorPublisher,
                Published(
                    title_in,
                    publications_in
                )
            )
        ) {
            // Do nothing
        }
    }


    // EDITOR
    public void low editor() {

        bool high received = false;
        String low title_in;
        String high manuscript_in;

        try_rcv(
            e(kAuthorEditorPublisher,
                Submission(title, manuscript))
        ) {

        }

        received = true;

        if (received) {
            bool high ok = true;
            if (manuscript_in != "SECRET_BOOK_CONTENT") {
                ok = false;
            }

            if (ok) {
                String high review = "APPROVED";

                e(kAuthorEditorPublisher, Approval) low approvalMsg = e(kAuthorEditorPublisher,
                    Approval(title_in, review)
                );

                send(approvalMsg);
            }
        }
    }


    // PUBLISHING TEAM
    public void low publishingTeam() {

        bool low ok = false;
        String low title_in = "";

        try_rcv(
            e(kAuthorEditorPublisher,
                Approval(
                    title_in,
                    review))
        ) {
        }

        ok = true;

        if (ok) {

            publications = publications + 1;

            print(title_in, publications);

            e(kAuthorEditorPublisher, Published) low resultMsg =
                e(kAuthorEditorPublisher, Published(title_in, publications));

            send(resultMsg);
        }
    }
}