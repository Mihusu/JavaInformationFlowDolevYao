public class BankTransfer {

    String low user = "Alice";
    String low target = "Bob";

    public void low client() {

        int high amount1 = 2000;
        int high amount2 = 3000;
        int high total;

        // encrypted messages (ciphertext is LOW)
        e(kClient,transfer1) low msg1 = e(kBank,
            Transfer1(String low user, int high amount1, String low target)
        );

        e(kClient,transfer2) low msg2 = e(kBank,
            Transfer2(String low user, int high amount2, String low target)
        );

        total = amount1 + amount2;

        send(msg1);
        send(msg2);

        print("Transferred " + total + " to " + target);
    }

    public void low bank() {

        int high total;
        bool high done;
        int high amount1;
        int high amount2;

        // First transfer
        try_rcv(e(kBank,
          Transfer1(String low user, int high amount1, String high target)
        )) {
        }

        // Second transfer
        try_rcv(e(kBank,
          Transfer2(String low user, int high amount2, String low target)
        )) {
          // Ignore catch
        }

        total = amount1 + amount2;
        done = true;

        // Encrypt result BEFORE sending
        e(kBank,transfer) low resultMsg = e(kReceiver,
          Result(String low user, bool high done, int high total)
        );

        send(resultMsg);
    }

    public void low clientReceiver() {
        try_rcv(e(kReceiver,
          Result(String low user, bool high done, int high total)
        )) {
          print("You received money from " + user + ". " + user + " has sent you " + total + ". Status: " + done);
        }
    }
}
