key kClientBank;
key kReceiverBank;
format Transfer1(String low user, int high amounts1, String low target);
format Transfer2(String low user, int high amount2, String low target);
format Transfer3(String low user, int high amounts3, String low target);
format Result(String low user, bool high done, int high total);

public class BankTransfer {

    String low user = "Alice";
    String low target = "Bob";

    public BankTransfer() {
        user = this.user;
        target = this.target;
    }

    public void low client() {
        int high amount1;
        int high amount2;
        int high amount3;
        int high amount4;
        int high total;

        print("Welcome to the bank.");
        print("Please enter the amounts you want to transfer.");
        print("In this program you can transfer money up to 3 times. You can deduct money after the third transfer.");

        print("Enter amount1:");
        input(amount1);
        print("Enter amount2:");
        input(amount2);
        print("Enter amount3:");
        input(amount3);
        print("Enter how much you want to deduct: ");
        input(amount4);

        Transfer1 high u = Transfer1(user, amount1, target);

        // encrypted messages (ciphertext is LOW)
        e(kClientBank,Transfer1) low msg1 = e(kClientBank, u);

        e(kClientBank,Transfer2) low msg2 = e(kClientBank,
            Transfer2(user, amount2, target)
        );

        e(kClientBank,Transfer3) low msg3 = e(kClientBank,
                    Transfer3(user,
                    amount3 - amount4, target)
        );

        total = amount1 + amount2 + amount3 - amount4;

        if(total < 0) {
            print("Transfer failed.");

        } else {
            print("Transferred " + total + " to " + target);
        }

        send(msg1);
        send(msg2);
        send(msg3);
    }

    public void low bank() {

        int high total;
        bool high done;
        int high amount1;
        int high amount2;
        int high amount3;
        e(kReceiverBank,Result) low resultMsg;

        // First transfer
        try_rcv(e(kClientBank,
          Transfer1(user, amount1, target)
        )) {
            print("Transfer failed");
        }

        // Second transfer
        try_rcv(e(kClientBank,
          Transfer2(user, amount2, target)
        )) {
            print("Transfer failed");
        }

        // Third transfer
        try_rcv(e(kClientBank,
          Transfer3(user, amount3, target)
        )) {
            print("Transfer failed");
        }

        total = amount1 + amount2 + amount3;

        if(total < 0) {
            print("Transfer failed.");

        } else {
            done = true;
        }

        // Encrypt result outside the high branch so the network action is public.
        resultMsg = e(kReceiverBank,
          Result(user, done, total)
        );

        send(resultMsg);
    }

    public void low clientReceiver() {
        try_rcv(e(kReceiverBank,
          Result(user, done, total)
        )) {
        }

        if(done && total > 0) {
            print("From bank:");
            print("You received money from " + user + ". " + user + " has sent you " + total + ". Status: " + done);

        }
    }

    client();
    bank();
    clientReceiver();
}
