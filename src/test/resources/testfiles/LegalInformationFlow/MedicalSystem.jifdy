key kPatientHospital;
format MedicalData(String low patientName, String high diagnosis, int high patientId);
format Result(String low received);

class PersonRecord {
    String low patientName = "";

    public String low getName() {
        return this.patientName;
    }
}

class PatientRecord extends PersonRecord {
    String high diagnosis = "";
    int high patientId = 0;

    public int high getPatientId() {
        return this.patientId;
    }
}

public class MedicalSystem {

    public void low patient() {

        PatientRecord low patientRecord = new PatientRecord();
        PersonRecord low publicRecord = patientRecord;

        input(publicRecord.patientName);
        input(patientRecord.diagnosis);
        input(patientRecord.patientId);

        // LOW key used for HIGH data
        e(kPatientHospital, MedicalData) low medicalMsg =
            e(kPatientHospital, MedicalData(
                publicRecord.getName(),
                patientRecord.diagnosis,
                patientRecord.getPatientId()
            ));

        send(medicalMsg);

        try_rcv(
            e(kPatientHospital, Result(received))) {
            print(received);
        }
    }


    public void low hospital() {

        bool low ok = true;
        String low patientName = "";
        String high diagnosis = "";
        int high patientId = 0;

        try_rcv(
            e(kPatientHospital, MedicalData(patientName, diagnosis, patientId))
        ) {
        }

        if (ok) {

            print(patientName);
            print(diagnosis);
            print(patientId);

            String low received = "RECEIVED";

            e(kPatientHospital, Result) low resultMsg =
                e(kPatientHospital, Result(received));

            send(resultMsg);
        }
    }
}
