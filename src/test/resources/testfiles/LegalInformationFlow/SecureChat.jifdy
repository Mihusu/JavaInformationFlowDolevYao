key kAliceBob;
format Message(String low user, String low text);

public class SecureChat {

    public bool low isAllowed(String low x) {

        if (x == "Hello") {
            return true;
        }
        else {
            return false;
        }
    }

    public void low alice() {

        String low user = "Alice";
        String low text = "Hello ";

        isAllowed(text);

        Message high f1 = Message(String low user, String low text);

        if(isAllowed(text) == true) {
            e(kAliceBob, Message) low msg =
                    e(kAliceBob, f1);

            send(msg);
        }
    }

    public void low bob() {

        bool high ok = true;

        try_rcv(e(kAliceBob,
                Message(String low user, String low text))
        ) {
            ok = false;
        }

        String low sender = user;

        if (ok) {
            print("Sender: " + sender, text);
        }
    }
}