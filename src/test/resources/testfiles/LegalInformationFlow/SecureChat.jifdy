public class SecureChat {

    public bool low isAllowed(String low x) {

        if (x == "Hello") {
            return true;
        }
        else {
            return false;
        }
    }

    public void low alice() {

        String low user = "Alice";
        String low text = "Hello";

        isAllowed(text);

        if(isAllowed(text) == true) {
            e(kAlice, Message) low msg =
                    e(kBob, Message(String low user, String low text));

            send(msg);
        }
    }

    public void low bob() {

        bool high ok = true;
        String low sender = "";
        String low text = "";

        try_rcv(e(kBob,
                Message(String low user, String low text))
        ) {
            ok = false;
        }

        sender = user;
        text = text;

        if (ok) {
            print(sender, text);
        }
    }
}