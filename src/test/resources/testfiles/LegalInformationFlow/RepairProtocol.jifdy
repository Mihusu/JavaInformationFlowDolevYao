key kCustomerRepairShop;
format RepairRequest(String low customerName, String low device, int high serial, String high issue);
format RepairStatus(String low repair, int high serial_in);
public class RepairProtocol {

    public RepairProtocol() {
    }

    public void low customer() {

        String low customerName = "Alice";
        String low device = "Laptop";

        int high serial = 998877;
        String high issue = "Broken motherboard";

        // SEND REPAIR REQUEST
        e(kCustomerRepairShop, RepairRequest) low repairMsg =
            e(kCustomerRepairShop, RepairRequest(customerName, device, serial, issue));

        send(repairMsg);


        // RECEIVE STATUS
        try_rcv(
            e(kCustomerRepairShop,
                RepairStatus(
                    status,
                    serial_in))
        ) {
        }

        if (status == "repaired") {
            print("Repaired");
        }
    }

    public void low repairShop() {

        bool low ok = true;
        String low customerName = "";
        String low device = "";
        int high serial = 0;
        String high issue = "";

        // RECEIVE REQUEST
        try_rcv(
            e(kCustomerRepairShop,
                RepairRequest(c, d, s, i))
        ) {
        }

        if (ok) {

            String low status = "repaired";

            e(kCustomerRepairShop, RepairStatus) low statusMsg = e(
                kCustomerRepairShop, RepairStatus(status, serial));

            send(statusMsg);
        }
    }
}
