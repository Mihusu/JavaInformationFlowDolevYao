key kCustomerRepairShop;
format RepairRequest(String low customerName, String low device, int high serial, String high issue);
format RepairStatus(String low repair, int high serial_in);
public class RepairProtocol {

    public void low customer() {

        String low customerName = "Alice";
        String low device = "Laptop";

        int high serial = 998877;
        String high issue = "Broken motherboard";

        // SEND REPAIR REQUEST
        e(kCustomerRepairShop, RepairRequest) low repairMsg =
            e(kCustomerRepairShop, RepairRequest(String low customerName, String low device, int high serial, String high issue));

        send(repairMsg);


        // RECEIVE STATUS
        try_rcv(
            e(kCustomerRepairShop,
                RepairStatus(
                    String low status,
                    int high serial_in))
        ) {
        }

        if (status == "repaired") {
            print("Repaired");
        }
    }

    public void low repairShop() {

        bool low ok = true;
        String low customerName = "";
        String low device = "";
        int high serial = 0;
        String high issue = "";

        // RECEIVE REQUEST
        try_rcv(
            e(kCustomerRepairShop,
                RepairRequest(
                    String low c,
                    String low d,
                    int high s,
                    String high i))
        ) {

        }

        if (ok) {

            String low status = "repaired";

            e(kCustomerRepairShop, RepairStatus) low statusMsg = e(kCustomerRepairShop, RepairStatus(String low status, int high serial));

            send(statusMsg);
        }
    }
}