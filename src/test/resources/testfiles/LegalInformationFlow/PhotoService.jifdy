key kClientServer;
format Login(String low user, String high password);
format Upload(String low user, String high photo);
format Ack(String low msg);
format AckMsg(String high uploaded);
public class PhotoService {

    public void low client() {

        String low user = "Alice";
        String high password = "1234";
        String high photo = "BINARYDATA";
        bool high ok;
        String high msg;

        // SEND LOGIN
        e(kClientServer, Login) low loginMsg =
            e(kClientServer, Login(String low user, String high password));

        send(loginMsg);

        // SEND UPLOAD
        e(kClientServer, Upload) low uploadMsg =
            e(kClientServer, Upload(String low user, String high photo));

        send(uploadMsg);

        ok = true;

        // RECEIVE ACK
        try_rcv(e(kClientServer,AckMsg(String high msg)
        )) {
            // receive FAILED -> mark failure
            ok = false;
        }

        // Only use msg if receive succeeded
        if (ok) {
            print(msg);   // LOW
        }
    }


    public void low server() {

        bool high ok;
        String high photo;

        // RECEIVE LOGIN
        try_rcv(e(kClientServer,
            Login(String low user, String high password)
        )) {
            ok = false;
        }

        // RECEIVE UPLOAD
        if (ok) {
            try_rcv(e(kClientServer,
                Upload(String low user2, String high photo_in)
            )) {
                ok = false;
            }
            photo = photo_in;
        }

        // PROCESS
        if (ok) {

            String high store = photo;
            String high uploaded = "uploaded";

            e(kClientServer, AckMsg) low ackMsg =
                e(kClientServer, AckMsg(String high uploaded));

            send(ackMsg);
        }
    }
}
